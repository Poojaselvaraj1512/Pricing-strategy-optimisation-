<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PriceIQ — Pricing Strategy Optimisation</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --cream: #f5f0e8;
  --warm-white: #faf8f4;
  --ink: #1a1612;
  --ink-soft: #3d3830;
  --muted: #8c8479;
  --border: #e2ddd5;
  --gold: #c9973a;
  --gold-light: #f0d9a8;
  --gold-pale: #fdf6e8;
  --teal: #2a7c6f;
  --teal-light: #d4ede9;
  --rose: #c0474b;
  --rose-light: #f5d9da;
  --slate: #4a6fa5;
  --slate-light: #dce8f5;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  background: var(--warm-white);
  color: var(--ink);
  font-family: 'DM Sans', sans-serif;
  font-weight: 400;
  overflow-x: hidden;
}

/* ─── NAV ─── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 48px;
  background: rgba(250,248,244,.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}

.nav-logo {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: -0.02em;
}

.nav-logo span { color: var(--gold); }

.nav-links {
  display: flex;
  gap: 36px;
  list-style: none;
}

.nav-links a {
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--muted);
  text-decoration: none;
  transition: color .2s;
}

.nav-links a:hover { color: var(--ink); }

.nav-cta {
  background: var(--ink);
  color: var(--cream) !important;
  padding: 8px 20px;
  border-radius: 4px;
  transition: background .2s !important;
}

.nav-cta:hover { background: var(--gold) !important; color: var(--ink) !important; }

/* ─── HERO ─── */
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding-top: 80px;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 80% 50%, rgba(201,151,58,.07) 0%, transparent 70%),
    radial-gradient(ellipse 40% 60% at 10% 80%, rgba(42,124,111,.05) 0%, transparent 60%);
  pointer-events: none;
}

.hero-grid-lines {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size: 60px 60px;
  opacity: 0.4;
  pointer-events: none;
}

.hero-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 80px 64px 80px 80px;
  position: relative;
  z-index: 1;
}

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 28px;
}

.hero-eyebrow::before {
  content: '';
  width: 32px;
  height: 1px;
  background: var(--gold);
}

h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.8rem, 4vw, 4.2rem);
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: -0.03em;
  color: var(--ink);
  margin-bottom: 24px;
}

h1 em {
  font-style: italic;
  color: var(--gold);
}

.hero-desc {
  font-size: 16px;
  line-height: 1.75;
  color: var(--ink-soft);
  max-width: 460px;
  margin-bottom: 44px;
}

.hero-actions {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.btn-primary {
  background: var(--ink);
  color: var(--cream);
  padding: 14px 32px;
  border-radius: 4px;
  font-size: 14px;
  font-weight: 500;
  text-decoration: none;
  transition: background .2s, transform .2s;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.btn-primary:hover { background: var(--gold); color: var(--ink); transform: translateY(-1px); }

.btn-outline {
  border: 1px solid var(--border);
  color: var(--ink);
  padding: 14px 32px;
  border-radius: 4px;
  font-size: 14px;
  font-weight: 500;
  text-decoration: none;
  transition: border-color .2s, background .2s;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.btn-outline:hover { border-color: var(--gold); background: var(--gold-pale); }

.hero-stats {
  display: flex;
  gap: 40px;
  margin-top: 60px;
  padding-top: 32px;
  border-top: 1px solid var(--border);
}

.hero-stat-val {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  font-weight: 700;
  color: var(--ink);
}

.hero-stat-label {
  font-size: 12px;
  color: var(--muted);
  margin-top: 2px;
  letter-spacing: 0.04em;
}

/* Hero right — animated dashboard mockup */
.hero-right {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80px 80px 80px 40px;
  position: relative;
  z-index: 1;
}

.dashboard-preview {
  width: 100%;
  max-width: 480px;
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 16px;
  box-shadow: 0 24px 80px rgba(26,22,18,.12), 0 4px 16px rgba(26,22,18,.06);
  overflow: hidden;
  animation: floatUp 0.8s ease both;
}

.dp-header {
  background: var(--ink);
  padding: 16px 20px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.dp-dot { width: 10px; height: 10px; border-radius: 50%; }
.dp-dot:nth-child(1) { background: #f87171; }
.dp-dot:nth-child(2) { background: #fbbf24; }
.dp-dot:nth-child(3) { background: #4ade80; }

.dp-title {
  margin-left: 8px;
  font-family: 'DM Mono', monospace;
  font-size: 12px;
  color: rgba(255,255,255,.5);
}

.dp-body { padding: 20px; }

.dp-section-label {
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 12px;
}

.dp-category-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}

.dp-cat-name {
  font-size: 12px;
  font-weight: 500;
  color: var(--ink);
  width: 100px;
  flex-shrink: 0;
}

.dp-bar-bg {
  flex: 1;
  height: 6px;
  background: var(--cream);
  border-radius: 99px;
  overflow: hidden;
}

.dp-bar {
  height: 100%;
  border-radius: 99px;
  animation: growBar 1.2s ease both;
}

.dp-bar-val {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--muted);
  width: 48px;
  text-align: right;
}

.dp-divider { height: 1px; background: var(--border); margin: 16px 0; }

.dp-metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.dp-metric {
  background: var(--cream);
  border-radius: 8px;
  padding: 12px;
}

.dp-metric-val {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  font-weight: 700;
  color: var(--ink);
}

.dp-metric-label {
  font-size: 10px;
  color: var(--muted);
  margin-top: 2px;
}

.dp-sensitivity-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
  font-size: 12px;
}

.dp-sensitivity-row:last-child { border-bottom: none; }

.sens-badge {
  font-size: 10px;
  padding: 3px 8px;
  border-radius: 99px;
  font-weight: 500;
}

.sens-less { background: var(--teal-light); color: var(--teal); }
.sens-more { background: var(--rose-light); color: var(--rose); }
.sens-mod  { background: var(--slate-light); color: var(--slate); }

@keyframes floatUp {
  from { opacity: 0; transform: translateY(30px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes growBar {
  from { width: 0; }
}

/* ─── SECTION BASE ─── */
section {
  padding: 100px 80px;
  max-width: 1280px;
  margin: 0 auto;
}

.section-header {
  max-width: 640px;
  margin-bottom: 64px;
}

.eyebrow {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--gold);
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 16px;
}

.eyebrow::before { content: ''; width: 24px; height: 1px; background: var(--gold); }

h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 3vw, 3rem);
  font-weight: 900;
  line-height: 1.1;
  letter-spacing: -0.03em;
  color: var(--ink);
  margin-bottom: 16px;
}

h2 em { font-style: italic; color: var(--gold); }

.section-desc {
  font-size: 15px;
  line-height: 1.75;
  color: var(--ink-soft);
}

/* ─── HOW IT WORKS ─── */
.how-it-works {
  background: var(--ink);
  max-width: 100%;
  padding: 100px 80px;
}

.how-it-works .section-header { margin: 0 auto 72px; }

.how-it-works h2 { color: var(--cream); }
.how-it-works .section-desc { color: rgba(245,240,232,.6); }
.how-it-works .eyebrow { color: var(--gold); }
.how-it-works .eyebrow::before { background: var(--gold); }

.steps-grid {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2px;
}

.step {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.07);
  padding: 36px 28px;
  position: relative;
  transition: background .3s;
}

.step:hover { background: rgba(201,151,58,.08); }

.step-num {
  font-family: 'Playfair Display', serif;
  font-size: 3.5rem;
  font-weight: 900;
  color: rgba(201,151,58,.2);
  line-height: 1;
  margin-bottom: 20px;
}

.step-icon {
  font-size: 28px;
  margin-bottom: 16px;
  display: block;
}

.step h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--cream);
  margin-bottom: 10px;
}

.step p {
  font-size: 13px;
  line-height: 1.7;
  color: rgba(245,240,232,.5);
}

.step-tag {
  display: inline-block;
  margin-top: 14px;
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--gold);
  letter-spacing: 0.06em;
}

/* ─── CATEGORIES / SENSITIVITY ─── */
.categories-section { padding: 100px 80px; }

.cat-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: start;
}

.cat-table-wrap {
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}

.cat-table {
  width: 100%;
  border-collapse: collapse;
}

.cat-table th {
  background: var(--cream);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  padding: 14px 20px;
  text-align: left;
  border-bottom: 1px solid var(--border);
}

.cat-table td {
  padding: 14px 20px;
  font-size: 14px;
  border-bottom: 1px solid var(--border);
  vertical-align: middle;
}

.cat-table tr:last-child td { border-bottom: none; }

.cat-table tr:hover td { background: var(--gold-pale); }

.badge {
  font-size: 11px;
  padding: 3px 10px;
  border-radius: 99px;
  font-weight: 500;
  white-space: nowrap;
}

.badge-less { background: var(--teal-light); color: var(--teal); }
.badge-more { background: var(--rose-light); color: var(--rose); }
.badge-mod  { background: var(--slate-light); color: var(--slate); }
.badge-high { background: var(--gold-light); color: #7a5a1a; }
.badge-low  { background: var(--cream); color: var(--muted); }

.price-up   { color: var(--teal); font-weight: 500; }
.price-down { color: var(--rose); font-weight: 500; }

/* Explainer card */
.explainer {
  background: var(--gold-pale);
  border: 1px solid var(--gold-light);
  border-radius: 12px;
  padding: 32px;
}

.explainer h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 16px;
}

.explainer-block {
  background: #fff;
  border: 1px solid var(--gold-light);
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
}

.explainer-block h4 {
  font-size: 13px;
  font-weight: 500;
  color: var(--ink);
  margin-bottom: 6px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.explainer-block p {
  font-size: 13px;
  line-height: 1.65;
  color: var(--ink-soft);
}

.formula-box {
  background: var(--ink);
  border-radius: 8px;
  padding: 14px 18px;
  margin-top: 16px;
  font-family: 'DM Mono', monospace;
  font-size: 12px;
  color: var(--gold-light);
  line-height: 1.8;
}

/* ─── REVENUE SECTION ─── */
.revenue-section {
  background: var(--cream);
  max-width: 100%;
  padding: 100px 80px;
}

.revenue-inner { max-width: 1200px; margin: 0 auto; }

.revenue-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-bottom: 48px;
}

.rev-card {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 28px;
  position: relative;
  overflow: hidden;
  transition: transform .25s, box-shadow .25s;
}

.rev-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(26,22,18,.1); }

.rev-card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 3px;
}

.rev-card.green::after { background: var(--teal); }
.rev-card.amber::after { background: var(--gold); }
.rev-card.rose::after  { background: var(--rose); }

.rev-card-eyebrow {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 8px;
}

.rev-card-val {
  font-family: 'Playfair Display', serif;
  font-size: 2.4rem;
  font-weight: 700;
  color: var(--ink);
  line-height: 1;
  margin-bottom: 6px;
}

.rev-card-sub {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.5;
}

.rev-change {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 13px;
  font-weight: 500;
  margin-top: 12px;
  padding: 4px 10px;
  border-radius: 99px;
}

.rev-change.up   { background: var(--teal-light); color: var(--teal); }
.rev-change.flat { background: var(--slate-light); color: var(--slate); }

/* Revenue bar chart */
.rev-chart {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 32px;
}

.rev-chart-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 28px;
}

.rev-bar-row {
  display: grid;
  grid-template-columns: 130px 1fr 1fr 80px;
  gap: 12px;
  align-items: center;
  margin-bottom: 14px;
}

.rev-bar-label { font-size: 13px; color: var(--ink); font-weight: 500; }

.rev-bar-track { position: relative; height: 28px; }

.rev-bar-fill {
  height: 100%;
  border-radius: 4px;
  display: flex;
  align-items: center;
  padding-left: 10px;
  font-size: 11px;
  font-weight: 500;
  transition: width 1.4s cubic-bezier(.23,1,.32,1);
}

.rev-bar-actual { background: rgba(42,124,111,.15); color: var(--teal); }
.rev-bar-suggested { background: rgba(201,151,58,.2); color: #7a5a1a; }

.rev-bar-delta {
  font-family: 'DM Mono', monospace;
  font-size: 12px;
  text-align: right;
}

.delta-pos { color: var(--teal); }
.delta-neg { color: var(--rose); }

/* ─── MODEL SECTION ─── */
.model-section { padding: 100px 80px; }

.model-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: start;
}

.model-left { }

.model-metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 28px;
}

.metric-card {
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 20px;
}

.metric-card-val {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  font-weight: 700;
  color: var(--ink);
}

.metric-card-label {
  font-size: 12px;
  color: var(--muted);
  margin-top: 4px;
}

.metric-card-sub {
  font-size: 11px;
  color: var(--teal);
  margin-top: 2px;
  font-weight: 500;
}

.pipeline-steps {
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}

.pipeline-step {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 18px 20px;
  border-bottom: 1px solid var(--border);
  transition: background .2s;
}

.pipeline-step:last-child { border-bottom: none; }
.pipeline-step:hover { background: var(--gold-pale); }

.pipeline-step-num {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: var(--ink);
  color: var(--cream);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 1px;
}

.pipeline-step h4 {
  font-size: 13px;
  font-weight: 500;
  color: var(--ink);
  margin-bottom: 3px;
}

.pipeline-step p {
  font-size: 12px;
  color: var(--muted);
  line-height: 1.5;
}

.pipeline-step code {
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  background: var(--cream);
  padding: 1px 5px;
  border-radius: 3px;
  color: var(--gold);
}

/* Classification report */
.clf-report {
  background: var(--ink);
  border-radius: 12px;
  padding: 28px;
  color: var(--cream);
}

.clf-report-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  font-weight: 700;
  margin-bottom: 20px;
  color: var(--cream);
}

.clf-table {
  width: 100%;
  border-collapse: collapse;
  font-family: 'DM Mono', monospace;
  font-size: 12px;
}

.clf-table th {
  color: var(--gold);
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 8px 12px;
  text-align: left;
  border-bottom: 1px solid rgba(255,255,255,.1);
}

.clf-table td {
  padding: 10px 12px;
  color: rgba(245,240,232,.8);
  border-bottom: 1px solid rgba(255,255,255,.05);
}

.clf-table tr:last-child td { border-bottom: none; }

.clf-val-good { color: #4ade80; }
.clf-val-mid  { color: var(--gold-light); }

/* ─── INSIGHTS ─── */
.insights-section {
  background: var(--ink);
  max-width: 100%;
  padding: 100px 80px;
}

.insights-inner { max-width: 1200px; margin: 0 auto; }

.insights-section .eyebrow { color: var(--gold); }
.insights-section .eyebrow::before { background: var(--gold); }
.insights-section h2 { color: var(--cream); }
.insights-section .section-desc { color: rgba(245,240,232,.6); }

.insights-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-top: 56px;
}

.insight-card {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 12px;
  padding: 28px;
  transition: background .25s, border-color .25s;
}

.insight-card:hover {
  background: rgba(201,151,58,.08);
  border-color: rgba(201,151,58,.3);
}

.insight-icon {
  font-size: 28px;
  margin-bottom: 16px;
  display: block;
}

.insight-card h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--cream);
  margin-bottom: 10px;
}

.insight-card p {
  font-size: 13px;
  line-height: 1.7;
  color: rgba(245,240,232,.5);
}

.insight-highlight {
  margin-top: 14px;
