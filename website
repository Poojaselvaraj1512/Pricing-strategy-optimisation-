<script>
  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        // Animate bars when revenue section enters view
        if (e.target.closest('.rev-chart')) {
          document.querySelectorAll('.rev-bar-fill').forEach(bar => {
            const w = bar.dataset.w;
            if (w) bar.style.width = w + '%';
          });
        }
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Animate dimension bars on view
  const barObserver = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.rev-bar-fill').forEach(bar => {
          const w = bar.dataset.w;
          if (w) setTimeout(() => { bar.style.width = w + '%'; }, 300);
        });
      }
    });
  }, { threshold: 0.3 });

  const revChart = document.querySelector('.rev-chart');
  if (revChart) barObserver.observe(revChart);

  // Stagger card animations
  document.querySelectorAll('.insight-card').forEach((card, i) => {
    card.style.transitionDelay = `${i * 0.08}s`;
  });

  document.querySelectorAll('.step').forEach((step, i) => {
    step.style.animationDelay = `${i * 0.12}s`;
  });
</script>
